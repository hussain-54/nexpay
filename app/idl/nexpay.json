{
  "version": "0.1.0",
  "name": "nexpay",
  "instructions": [
    {
      "name": "initializeWallet",
      "accounts": [
        {
          "name": "walletAccount",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "sendPayment",
      "accounts": [
        {
          "name": "senderWallet",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "recipientWallet",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "sender",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "recipient",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "amount",
          "type": "u64"
        }
      ]
    },
    {
      "name": "closeWallet",
      "accounts": [
        {
          "name": "walletAccount",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "owner",
          "isMut": true,
          "isSigner": true
        }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "WalletAccount",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "owner",
            "type": "publicKey"
          },
          {
            "name": "totalSent",
            "type": "u64"
          },
          {
            "name": "totalReceived",
            "type": "u64"
          },
          {
            "name": "txCount",
            "type": "u64"
          },
          {
            "name": "createdAt",
            "type": "i64"
          }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "PaymentSent",
      "fields": [
        {
          "name": "sender",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "recipient",
          "type": "publicKey",
          "index": false
        },
        {
          "name": "amount",
          "type": "u64",
          "index": false
        },
        {
          "name": "timestamp",
          "type": "i64",
          "index": false
        }
      ]
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "InsufficientAmount",
      "msg": "Payment amount must be greater than zero"
    },
    {
      "code": 6001,
      "name": "InsufficientFunds",
      "msg": "Sender does not have enough SOL"
    },
    {
      "code": 6002,
      "name": "Unauthorized",
      "msg": "You are not the wallet owner"
    }
  ],
  "metadata": {
    "address": "11111111111111111111111111111111"
  }
}
